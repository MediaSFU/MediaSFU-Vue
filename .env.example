# MediaSFU local development settings
# Get development credentials from https://mediasfu.com/
# Do not ship real credentials in a frontend production bundle.
# For production, proxy create/join room requests through your backend.

VITE_MEDIASFU_API_USERNAME=your_api_username_here
VITE_MEDIASFU_API_KEY=your_64_character_api_key_here
VITE_MEDIASFU_USE_ENV_CREDENTIALS=false
VITE_MEDIASFU_LOCAL_LINK=
